<view class="page">
  <view class="welcome">{{loggedIn ? '你好，' + displayName : '欢迎使用赛果信息助手'}}</view>
  <view class="hint">{{loggedIn ? '功能与网页端 home 一致' : '可先浏览已完场比赛曲线图；账户、会员、充值等功能需注册登录后使用。'}}</view>
  <view wx:if="{{!loggedIn}}" class="login-entry" bindtap="onLogin">注册 / 登录</view>

  <view class="card menu">
    <view class="item" bindtap="go" data-url="/pages/curves/curves">
      <text>曲线图查询</text>
      <text class="chev">›</text>
    </view>
    <view class="item" bindtap="go" data-url="/pages/account/account">
      <text>账户资料</text>
      <text class="chev">›</text>
    </view>
    <view class="item" bindtap="go" data-url="/pages/membership/membership">
      <text>会员状态</text>
      <text class="chev">›</text>
    </view>
    <view class="item" bindtap="go" data-url="/pages/recharge/recharge">
      <text>充值 / 开通会员</text>
      <text class="chev">›</text>
    </view>
    <view class="item last" bindtap="go" data-url="/pages/records/records">
      <text>充值记录</text>
      <text class="chev">›</text>
    </view>
  </view>

  <view wx:if="{{loggedIn}}" class="logout" bindtap="onLogout">退出登录</view>
</view>
