<scroll-view wx:if="{{loading}}" class="center">
  <text class="muted">加载中…</text>
</scroll-view>

<scroll-view wx:elif="{{err}}" class="pad">
  <view class="card err-box">
    <text class="err">{{err}}</text>
  </view>
</scroll-view>

<scroll-view wx:else scroll-y class="scroll" enhanced show-scrollbar="{{false}}">
  <view class="status {{isMember ? 'member' : 'not-member'}}">
    <text class="status-hint">当前状态</text>
    <view class="badge {{isMember ? 'yes' : 'no'}}">
      <text class="badge-t">{{isMember ? '会员有效' : '非会员'}}</text>
    </view>
    <block wx:if="{{isMember && expiresAt}}">
      <text class="expire">会员到期时间（最晚）：\n<text class="strong">{{expiresAtFmt}}</text></text>
      <text wx:if="{{daysLeft !== null}}" class="days">{{daysText}}</text>
    </block>
  </view>

  <text class="sec-title">当前有效权益明细</text>
  <text class="sec-hint">多条记录同时有效时，到期时间取最晚一条；下列为当前仍在有效期内的片段。</text>

  <view wx:if="{{!records.length}}" class="card empty-box">
    <text class="empty">当前没有生效中的会员权益。</text>
  </view>

  <view wx:for="{{records}}" wx:key="index" class="card rec">
    <view class="rec-row"><text class="rec-l">类型</text><text class="rec-r">{{item.membership_type_label || item.membership_type || '—'}}</text></view>
    <view class="rec-row"><text class="rec-l">来源</text><text class="rec-r">{{item.source_label || item.source || '—'}}</text></view>
    <view class="rec-row"><text class="rec-l">生效时间</text><text class="rec-r">{{item.effFmt}}</text></view>
    <view class="rec-row"><text class="rec-l">到期时间</text><text class="rec-r">{{item.expFmt}}</text></view>
    <view class="rec-row"><text class="rec-l">订单号</text><text class="rec-r mono">{{item.orderShort}}</text></view>
  </view>

  <view wx:if="{{giftText}}" class="gift">
    <text>{{giftText}}</text>
  </view>
</scroll-view>
