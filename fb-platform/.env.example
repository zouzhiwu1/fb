# MySQL（必填）请把 YOUR_MYSQL_USER 和 YOUR_MYSQL_PASSWORD 改成你本机的 MySQL 用户名和密码
DATABASE_URL=mysql+pymysql://YOUR_MYSQL_USER:YOUR_MYSQL_PASSWORD@localhost:3306/fb

# JWT 密钥（必填，用于登录 token）
JWT_SECRET_KEY=请改为随机长字符串

# 短信配置（发送验证码）
# 开发时可留空，使用“模拟发送”（控制台输出验证码）
# 生产环境填写具体厂商的 key/secret，见 README
SMS_PROVIDER=mock
# SMS_ACCESS_KEY_ID=
# SMS_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=

# 验证码有效期（秒）
SMS_CODE_EXPIRE=300

# 工作目录（可选）：与 pipeline 的 WORK_SPACE 一致时，曲线图目录默认为 WORK_SPACE/fb-report
# WORK_SPACE=/Users/zhiwuzou/Documents/cursor

# 曲线图目录（不设则使用 WORK_SPACE/fb-report）
# CURVE_IMAGE_DIR=/path/to/fb-report

# 曲线图权限：默认（不设）= 仅有效会员可看任何曲线。若需按设计书「非会员可看完场/历史」则设为 0
# CURVES_REQUIRE_ACTIVE_MEMBERSHIP=0

# ---------- 支付宝 / 会员购买（可选）----------
# ALIPAY_MODE=mock          # mock=本地联调不验签；rsa=验签（需配置公钥）
# ALIPAY_MOCK_SECRET=       # 非空时模拟回调须带 Header: X-Alipay-Mock-Secret
# ALIPAY_APP_ID=
# ALIPAY_PUBLIC_KEY_PEM=    # 或 ALIPAY_PUBLIC_KEY_PATH 指向 PEM 文件
# PUBLIC_BASE_URL=https://你的域名   # 微信/支付宝异步通知须公网 HTTPS
# MEMBERSHIP_PRICES_JSON={"month":"1000.00","week":"9.90"}

# ---------- 微信小程序 JSAPI 支付（可选）----------
# 与 fb-miniprogram 的 appid 一致；需在商户平台绑定该小程序 AppID
# WECHAT_MP_APP_ID=
# WECHAT_MP_APP_SECRET=
# WECHAT_MCH_ID=
# WECHAT_PAY_MODE=mock         # mock=联调；v2=V2 统一下单+XML 回调；v3=V3 JSON+证书
# WECHAT_MOCK_SECRET=          # mock 时可要求 Header: X-Wechat-Mock-Secret
# --- V2（WECHAT_PAY_MODE=v2）---
# WECHAT_API_KEY=              # 商户平台 API 密钥（MD5 paySign 与回调验签）
# --- V3（WECHAT_PAY_MODE=v3）---
# WECHAT_MCH_CERT_PATH=        # apiclient_cert.pem；可不填 WECHAT_MCH_CERT_SERIAL（从证书解析）
# WECHAT_MCH_CERT_SERIAL=      # 若已填则优先；否则需 WECHAT_MCH_CERT_PATH 或 WECHAT_MCH_CERT_PEM
# WECHAT_MCH_PRIVATE_KEY_PATH= # apiclient_key.pem；或 WECHAT_MCH_PRIVATE_KEY_PEM 内联
# WECHAT_PLATFORM_PUBLIC_KEY_ID=   # 微信支付平台公钥 ID（文档 PUB_KEY_ID_…）
# WECHAT_PLATFORM_PUBLIC_KEY_PATH= # 平台公钥 PEM；或 WECHAT_PLATFORM_PUBLIC_KEY_PEM
# WECHAT_API_V3_KEY=           # 商户平台「APIv3 密钥」，UTF-8 须 32 字节（解密回调 resource）
# 已有 MySQL 库新增用户列：scripts/add_wechat_mp_openid.sql
