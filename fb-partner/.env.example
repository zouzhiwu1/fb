# 与 platform 可共用同一库
DATABASE_URL=mysql+pymysql://USER:PASSWORD@127.0.0.1:3306/fb

# 须与 platform 的 JWT_SECRET_KEY 不同
PARTNER_JWT_SECRET_KEY=your-partner-only-secret-min-32-chars

# 可选：登录 token 有效期（小时），默认 168
# PARTNER_JWT_EXPIRE_HOURS=168

# 可选：bootstrap 接口密钥（请求头 X-Partner-Bootstrap-Key）
#   POST /api/partner/auth/bootstrap-admin — 创建首个库内管理员（登录名不可为 root）
#   POST /api/partner/auth/bootstrap-agent — 直连创建代理商（可不填档案）
# PARTNER_BOOTSTRAP_KEY=

# 部署根账号：登录名固定 root（不区分大小写），密码如下；不入库
PARTNER_ROOT_PASSWORD=change-me-strong-password
# 可选：整数，修改后根账号旧 JWT 全部失效
# PARTNER_ROOT_SESSION_VERSION=1

# 拉新服务费：每名拉新写入 agent_commission_lines 的金额系数（默认 1，与 fb-platform PARTNER_REG_FACTOR 一致）
# PARTNER_REG_FACTOR=1
# 兼容保留（月度看板不再用于计费）：旧版「业绩/积分」口径
# PARTNER_YUAN_PER_VALID_REGISTRATION=1
# PARTNER_COMMISSION_PER_POINT=1
# 可选：计入「注册奖励」的 points_ledger.event_type，逗号分隔（平台写流水时可用；月度看板不展示）
# PARTNER_LEDGER_EVENT_TYPES_REG=registration,register,reg_bonus,user_register

# 代理商看板「推广二维码」：以下须复制到实际使用的 .env（本 .env.example 仅模板，进程不读取）
# 模板占位符：{agent_id}=库内主键 agents.id（常为小整数，与 users.agent_id / 看板统计一致）；
#             {agent_code}=推广码（对外展示）。若希望链接里用推广码，用 ?ref={agent_code}，且须客户端/注册接口按推广码解析并绑定正确代理。
# 微信小程序：扫码打开的 HTTPS；不配时可设 PARTNER_PROMO_H5_BASE 自动拼 open-weapp
# H5 落地页须由 fb-platform 提供路由 /invite-mp（见 platform INVITE_MP_*），域名反代到 platform
# PARTNER_PROMO_MP_QR_TARGET=https://trybx.cn/invite-mp?agent_id={agent_id}
# PARTNER_PROMO_H5_BASE=https://trybx.cn
# 方案 B（推荐）：由服务端调用微信 API 生成代理专属小程序码（scene=agent_id）
# PARTNER_PROMO_MP_APP_ID=wx38c79bc568eeda9a
# PARTNER_PROMO_MP_APP_SECRET=你的小程序AppSecret
# PARTNER_PROMO_MP_ENTRY_PAGE=pages/register/register
# 小程序码环境：trial=体验版，release=线上版（默认 trial）
# PARTNER_PROMO_MP_CODE_ENV_VERSION=trial
# 小程序码宽度（默认 430）
# PARTNER_PROMO_MP_CODE_WIDTH=430
# 开户时生成的小程序推广码 PNG 保存目录（可选）。不设则默认：<monorepo 根>/fb-agent-qrcode/{agent_id}.png
# PARTNER_AGENT_QR_STORAGE_DIR=/var/lib/fb-agent-qrcode
# WEB 端（H5/网页注册落地页）
# PARTNER_PROMO_WEB_URL=https://trybx.cn/register?ref={agent_id}
# APK 文件名勿拼错：football 不是 footboll
# PARTNER_PROMO_ANDROID_URL=https://trybx.cn/downloads/fb.apk?ref={agent_id}
# PARTNER_PROMO_IOS_URL=https://apps.apple.com/cn/app/idXXXX?ref={agent_id}

# 反代子路径时填写（如 /partner），与浏览器地址前缀一致；根路径部署留空
# PARTNER_APPLICATION_PREFIX=

# 本地需要 Flask 调试与自动重载时再设 FLASK_DEBUG=1（否则 500 易返回 HTML，管理页无法解析）
# FLASK_DEBUG=1

PORT=5002

