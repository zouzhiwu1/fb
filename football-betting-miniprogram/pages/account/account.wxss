.scroll {
  min-height: 100vh;
  padding-bottom: 80rpx;
}

.section {
  margin: 32rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f9fafb;
  margin-bottom: 24rpx;
}

.row {
  font-size: 28rpx;
  color: #9ca3af;
  margin-bottom: 12rpx;
}

.note {
  font-size: 26rpx;
  color: #9ca3af;
  margin-bottom: 20rpx;
}

.ph {
  color: #6b7280;
}

.secondary {
  background: #60a5fa;
  color: #fff;
  font-weight: 600;
  text-align: center;
  padding: 24rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.secondary.disabled {
  opacity: 0.55;
}
