.scroll {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 80rpx;
  box-sizing: border-box;
}

.form {
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.chips {
  max-height: 72rpx;
  margin-bottom: 16rpx;
  white-space: nowrap;
}

.chip-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 0;
}

.chip {
  display: inline-block;
  padding: 16rpx 24rpx;
  background: #1f2937;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #f9fafb;
}

.img-card {
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f9fafb;
  margin-bottom: 16rpx;
}

.img {
  width: 100%;
  display: block;
  background: #050816;
  border-radius: 12rpx;
}

.img-err {
  padding: 40rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 26rpx;
}
