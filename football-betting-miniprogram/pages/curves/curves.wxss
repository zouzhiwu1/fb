.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  min-height: 0;
  padding: 32rpx;
  padding-bottom: 80rpx;
  box-sizing: border-box;
}

.form {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.results-scroll {
  flex: 1;
  min-height: 0;
}

.inline-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.img-card {
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f9fafb;
  margin-bottom: 16rpx;
}

.img {
  width: 100%;
  display: block;
  background: #050816;
  border-radius: 12rpx;
}

.img-err {
  padding: 40rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 26rpx;
}
